[sub_resource type="ProceduralSkyMaterial" id="sky_mat"]

[sub_resource type="Sky" id="sky"]
sky_material = SubResource("sky_mat")

[sub_resource type="Environment" id="env"]
background_mode = 2
sky = SubResource("sky")
; Тун любит РОВНЫЙ заполняющий свет: ambient как цвет (source=2), а не из неба.
; Энергию ambient крутит world/Lighting.gd по времени суток — здесь базовое значение.
ambient_light_source = 2
ambient_light_color = Color(0.7, 0.8, 0.95, 1)
ambient_light_energy = 0.5
tonemap_mode = 2
; Glow (bloom) слабый — даёт лёгкое «акварельное» свечение ярких мест.
glow_enabled = true
glow_intensity = 0.2
glow_bloom = 0.05
glow_hdr_threshold = 0.9
; Лёгкая подкрутка цвета — насыщеннее и чуть контрастнее (мультяшно).
adjustment_enabled = true
adjustment_saturation = 1.15
adjustment_contrast = 1.05
; Голубоватый слабый туман — фирменная глубина Wind Waker.
fog_enabled = true
fog_light_color = Color(0.7, 0.82, 0.95, 1)
fog_density = 0.0015
; Для плоских заливок отключаем «грязнящие» эффекты (по умолчанию и так off).
ssao_enabled = false
ssil_enabled = false
sdfgi_enabled = false

